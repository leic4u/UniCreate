{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UniCreate",
  "version": "1.0.4",
  "identifier": "com.drrakendu78.unicreate",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "UniCreate",
        "width": 960,
        "height": 680,
        "resizable": true,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.github.com https://github.com https://avatars.githubusercontent.com; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost https://avatars.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../updater/src-tauri/target/release/unicreate-updater.exe": "UniCreate-Updater.exe"
    }
  }
}
